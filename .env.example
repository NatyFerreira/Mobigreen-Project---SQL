# Copier en .env et renseigner vos identifiants

# Connexion PostgreSQL (variables individuelles — utilisees dans les notebooks)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mobigreen_urban

# URL complete (utilisee par le package src/mobigreen)
DATABASE_URL=postgresql+psycopg2://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
